{
  "name": "@aiready/core",
  "version": "0.24.24",
  "description": "Shared utilities for AIReady analysis tools",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "require": "./dist/client/index.js",
      "import": "./dist/client/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/client/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/client/index.ts --format cjs,esm --watch",
    "test": "vitest run --hookTimeout=30000",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build",
    "release": "pnpm build && pnpm publish --no-git-checks",
    "type-check": "tsc --noEmit",
    "format-check": "prettier --check . --ignore-path ../../.prettierignore",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "aiready",
    "code-analysis",
    "utilities"
  ],
  "author": "AIReady Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/getaiready/aiready-core.git"
  },
  "homepage": "https://github.com/getaiready/aiready-core",
  "bugs": {
    "url": "https://github.com/getaiready/aiready-core/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "devDependencies": {
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "sst": "4.3.1",
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@typescript-eslint/parser": "^8.58.0",
    "@typescript-eslint/typescript-estree": "^8.58.0",
    "@unit-mesh/treesitter-artifacts": "^1.7.7",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "minimatch": "^10.2.5",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^6.0.2",
    "web-tree-sitter": "^0.26.8",
    "zod": "^4.3.6"
  }
}
